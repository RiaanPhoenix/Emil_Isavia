# Emil Isavia - Environment Variables Example
# Copy this file to .env and fill in your actual values

# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ENVIRONMENT=development
DEBUG=true
PORT=5000

# Aviation API Keys (optional - system works with mock data)
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here
AIRLABS_API_KEY=your_airlabs_api_key_here
# OpenSky Network doesn't require an API key

# Gurobi License (optional - system falls back to heuristics)
GUROBI_LICENSE_FILE=/path/to/your/gurobi.lic
GUROBI_HOME=/opt/gurobi1000/linux64

# Database Configuration (for future expansion)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=emil_isavia
DB_USER=postgres
DB_PASSWORD=your_db_password

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/emil_isavia.log